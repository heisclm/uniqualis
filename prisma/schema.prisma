// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------
enum Role {
  STUDENT
  LECTURER
  OFFICIAL // Deans, HODs
  ADMIN    // QA Officer, System Admin
}

// -----------------------------------------------------------------------------
// CORE ACADEMIC INFRASTRUCTURE
// -----------------------------------------------------------------------------
model Faculty {
  id          String       @id @default(uuid())
  name        String       @unique
  departments Department[]
  officials   User[]       @relation("FacultyOfficials")
  students    User[]       @relation("StudentFaculty")
  provisionedAccounts ProvisionedAccount[] @relation("ProvisionedFaculty")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Department {
  id          String       @id @default(uuid())
  name        String
  facultyId   String
  faculty     Faculty      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  courses     Course[]
  lecturers   User[]       @relation("LecturerDepartment")
  officials   User[]       @relation("DepartmentOfficials")
  provisionedAccounts ProvisionedAccount[] @relation("ProvisionedDepartment")
  evaluationTemplates EvaluationTemplate[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([name, facultyId])
}

model Course {
  id           String       @id @default(uuid())
  code         String       @unique // e.g., CS101
  title        String
  level        Int?         // e.g., 100, 200, 300
  departmentId String
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  lecturers    CourseLecturer[]
  evaluations  Evaluation[]
  enrollments  StudentEnrollment[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// -----------------------------------------------------------------------------
// USER MANAGEMENT & RBAC
// -----------------------------------------------------------------------------
model ProvisionedAccount {
  id          String   @id @default(uuid())
  email       String   @unique
  role        Role
  
  // Scopes
  facultyId    String? 
  faculty      Faculty?    @relation("ProvisionedFaculty", fields: [facultyId], references: [id])
  departmentId String? 
  department   Department? @relation("ProvisionedDepartment", fields: [departmentId], references: [id])
  
  isClaimed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  firstName       String
  lastName        String
  role            Role
  profileImageUrl String?   // Hosted on Cloudinary

  // Relationships based on Role
  studentFacultyId String?
  studentFaculty   Faculty? @relation("StudentFaculty", fields: [studentFacultyId], references: [id])
  studentIdNumber  String?  @unique // specific to STUDENT
  studentLevel     Int?     // e.g., 100, 200, 300, 400

  lecturerDepartmentId String?
  lecturerDepartment   Department? @relation("LecturerDepartment", fields: [lecturerDepartmentId], references: [id])
  coursesTaught        CourseLecturer[]

  // For Officials (Deans/HODs) restricted to specific scopes
  officialFacultyId    String?
  officialFaculty      Faculty?    @relation("FacultyOfficials", fields: [officialFacultyId], references: [id])
  officialDepartmentId String?
  officialDepartment   Department? @relation("DepartmentOfficials", fields: [officialDepartmentId], references: [id])

  studentEnrollments  StudentEnrollment[]   @relation("StudentEnrollments")
  adminCommentsMade   AdministrativeComment[]
  lecturerResponses   LecturerResponse[]
  notifications       Notification[]        @relation("UserNotifications")
  evaluationTokens    EvaluationToken[]     @relation("EvaluationTokens")
  
  // Settings / Preferences
  notifyWeeklyDigest  Boolean @default(true)
  notifyLowAverage    Boolean @default(true)
  notifyEvalWindow    Boolean @default(true)
  notifySubmissionReceipt Boolean @default(true)
  
  // Professional Information (For Lecturers)
  title               String?
  officeHours         String?
  shortBio            String?   @db.Text
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([role])
}

model CourseLecturer {
  id         String   @id @default(uuid())
  courseId   String
  lecturerId String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lecturer   User     @relation(fields: [lecturerId], references: [id], onDelete: Cascade)
  
  evaluations Evaluation[]
  evaluationTokens EvaluationToken[]

  @@unique([courseId, lecturerId])
  @@index([courseId])
  @@index([lecturerId])
}

// -----------------------------------------------------------------------------
// EVALUATIONS & FEEDBACK ENGINE
// -----------------------------------------------------------------------------
model Evaluation {
  id               String         @id @default(uuid())
  courseId         String
  course           Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseLecturerId String
  courseLecturer   CourseLecturer @relation(fields: [courseLecturerId], references: [id], onDelete: Cascade)
  
  templateId       String?
  template         EvaluationTemplate? @relation(fields: [templateId], references: [id])

  academicDate     DateTime
  timeSlot         String
  
  ratingQuantitative Int          // 1 to 5 Stars (Legacy / Summary)
  ratingQualitative  String?      @db.Text
  isFlagged          Boolean        @default(false)

  // AI-Powered Analysis
  sentimentScore     String?        // POSITIVE, NEUTRAL, NEGATIVE
  themes             String[]       // Array of tags e.g. ["Course Pacing", "Exam Difficulty"]

  adminComments      AdministrativeComment[]
  lecturerResponse   LecturerResponse?
  responses          EvaluationResponse[]

  createdAt        DateTime       @default(now())

  @@index([courseId])
  @@index([courseLecturerId])
}

model LecturerResponse {
  id             String     @id @default(uuid())
  evaluationId   String     @unique
  evaluation     Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  lecturerId     String
  lecturer       User       @relation(fields: [lecturerId], references: [id])
  
  content        String     @db.Text
  status         String     @default("PENDING_REVIEW") // PENDING_REVIEW, APPROVED, NEEDS_REVISION
  officialNotes  String?    @db.Text
  
  attachments    Attachment[]
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model AdministrativeComment {
  id             String     @id @default(uuid())
  evaluationId   String
  evaluation     Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  officialId     String
  official       User       @relation(fields: [officialId], references: [id])
  
  content        String     @db.Text
  isCommendation Boolean    @default(false)
  
  attachments    Attachment[]
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Attachment {
  id                    String                 @id @default(uuid())
  url                   String                 // Cloudinary URL
  publicId              String                 // Cloudinary Public ID
  fileName              String
  fileType              String                 // e.g., image/png, application/pdf
  
  lecturerResponseId    String?
  lecturerResponse      LecturerResponse?      @relation(fields: [lecturerResponseId], references: [id], onDelete: Cascade)
  
  adminCommentId        String?
  adminComment          AdministrativeComment? @relation(fields: [adminCommentId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime               @default(now())
}

model Notification {
  id          String   @id @default(uuid())
  recipientId String
  recipient   User     @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  
  title       String
  message     String
  isRead      Boolean  @default(false)
  link        String?
  
  createdAt   DateTime @default(now())
  
  @@index([recipientId, isRead])
  @@index([createdAt])
}

model StudentEnrollment {
  id           String   @id @default(uuid())
  studentId    String
  student      User     @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  academicYear String   // e.g. "2026-2027"
  semester     Int      // 1 or 2
  
  createdAt    DateTime @default(now())

  @@unique([studentId, courseId, academicYear, semester])
  @@index([studentId])
  @@index([courseId])
}

model EvaluationTemplate {
  id           String      @id @default(uuid())
  name         String
  description  String?
  status       String      @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  departmentId String?     // null means institution-wide
  department   Department? @relation(fields: [departmentId], references: [id])
  criteria     Criterion[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  evaluations  Evaluation[]
}

model Criterion {
  id           String             @id @default(uuid())
  templateId   String
  template     EvaluationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  question     String
  type         String             // SCALE, QUALITATIVE
  options      String?            // JSON string for options if any
  order        Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  
  responses    EvaluationResponse[]
}

model EvaluationResponse {
  id             String     @id @default(uuid())
  evaluationId   String
  evaluation     Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  criterionId    String
  criterion      Criterion  @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  score          Int?       // For SCALE
  text           String?    @db.Text // For QUALITATIVE
  
  @@unique([evaluationId, criterionId])
}

model EvaluationToken {
  id               String         @id @default(uuid())
  token            String         @unique
  studentId        String
  student          User           @relation("EvaluationTokens", fields: [studentId], references: [id], onDelete: Cascade)
  courseLecturerId String
  courseLecturer   CourseLecturer @relation(fields: [courseLecturerId], references: [id], onDelete: Cascade)
  isUsed           Boolean        @default(false)
  createdAt        DateTime       @default(now())
  usedAt           DateTime?

  @@unique([studentId, courseLecturerId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model SystemSetting {
  id                    String   @id @default(uuid())
  currentTermName       String   @default("Fall 2026")
  defaultDepartmentView String   @default("All Departments")
  evalWindowStartDate   DateTime @default(now())
  evalWindowEndDate     DateTime @default(now())
  autoClosePortal       Boolean  @default(true)
  updatedAt             DateTime @updatedAt
}
